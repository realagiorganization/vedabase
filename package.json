{
  "name": "vedabase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10",
  "scripts": {
    "dev": "vite",
    "data:sync:vedabase": "node scripts/sync-vedabase-dump.mjs",
    "data:sync:youtube": "node scripts/sync-youtube-search.mjs",
    "data:generate": "node scripts/generate-remote-data-module.mjs",
    "data:verify": "npm run data:generate && node scripts/verify-remote-datasources.mjs",
    "docs:generate": "node scripts/generate-docs.mjs",
    "docs:test": "npm run build && node scripts/verify-docs-site.mjs",
    "prebuild": "npm run docs:generate && npm run data:generate",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/prepare-pages-spa.mjs",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "verify": "npm run lint && npm run typecheck && npm run test -- --run && npm run build",
    "verify:strict": "npm run lint && npm run typecheck && npm run test:ci && npm run data:verify && npm run docs:test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "framer-motion": "^11.11.17"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "@vitest/coverage-v8": "^2.1.4"
  }
}
