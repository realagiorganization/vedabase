{
  "name": "ds-hymn-rom",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate": "node scripts/generate-static.mjs",
    "generate:check": "node scripts/generate-static.mjs --check",
    "readme:check": "node scripts/media-links.mjs --check-readme",
    "lint": "eslint . --ext js,mjs --max-warnings 0",
    "test": "vitest run",
    "test:bdd": "vitest run tests/bdd-counterparts.test.mjs",
    "test:ci": "vitest run --coverage",
    "verify": "npm run generate && npm run lint && npm run test:ci && python3 -m unittest discover -s tests -p 'test_ocr_ui_media.py' && npm run test:bdd && npm run generate:check && npm run readme:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "vitest": "^2.1.4"
  }
}
